msgstr "Journalisation des appels de fonction activée pour {function}"

#. Translators: Reported when toggling the function call log feature.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:57
msgid "Function calls log disabled"
msgstr "Journalisation des appels de fonction désactivé"

#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:62
msgid "Toggles the function calls log method."
msgstr "Sélectionne la méthode de journalisation des appels de fonction."

#. Translators: Reported when toggling the function calls log method.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:76
#, python-brace-format
msgid "Function calls log uses {method}"
msgstr "La journalisation des appels de fonction utilise {method}"

#. Translators: Reported when toggling the function calls log feature.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:91
#, python-brace-format
msgid "{func} is not a valid function name."
msgstr "{func} n'est pas un nom de fonction valide."

#. Translators: Reported when toggling the function calls log feature.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:206
#, python-brace-format
msgid "{location} is not a valid object name."
msgstr "{location} n'est pas un nom d'objet valide."

#. Translators: Reported when toggling the function calls log feature.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:212
#, python-brace-format
msgid "{name} is not a valid function name."
msgstr "{name} n'est pas un nom de fonction valide."

#. Translators: Part of the description for the layered command script.
