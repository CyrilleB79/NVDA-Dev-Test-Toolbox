msgstr "Gestionnaire de journaux"

#. Translators: the label for the text on top of the logs manager window.
#: addon\globalPlugins\ndtt\logManagement.py:371
#, python-brace-format
msgid "Logs in {folder}"
msgstr "Journaux dans {folder}"

#. Translators: The label for a column in logs list
#: addon\globalPlugins\ndtt\logManagement.py:387
msgid "Date"
msgstr "Date"

#. Translators: The label for a column in logs list
#: addon\globalPlugins\ndtt\logManagement.py:389
msgid "Type"
msgstr "Type"

#. Translators: The label for a column in logs list
#: addon\globalPlugins\ndtt\logManagement.py:391
msgid "File name"
msgstr "Nom du fichier"

#. Translators: The label for a button in Logs Manager dialog to open the selected logs.
#: addon\globalPlugins\ndtt\logManagement.py:399
