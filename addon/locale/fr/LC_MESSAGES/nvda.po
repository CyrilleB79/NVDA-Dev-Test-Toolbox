#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\beepError.py:95
msgid "Toggles play a sound for logged error."
msgstr "Active ou désactive l'émission d'un son pour une erreur enregistrée."

#. Translators: Message reported when calling the command to toggle play a sound for logged errors
#: addon\globalPlugins\ndtt\beepError.py:102
msgid "Yes"
msgstr "Oui"

#. Translators: Message reported when calling the command to toggle play a sound for logged errors
#: addon\globalPlugins\ndtt\beepError.py:106
msgid "Only in NVDA test versions"
msgstr "Uniquement dans les versions de test de NVDA"

#. Translators: Input help mode message for a command.
#: addon\globalPlugins\ndtt\beepError.py:111
msgid ""
"Report the last error logged. A second press clears the memorized last error."
msgstr ""
"Annonce la dernière erreur enregistrée dans le journal. Un deuxième appui "
"efface la dernière erreur mémorisée."

#. Translators: Message reported when calling the "report last error" command
#: addon\globalPlugins\ndtt\beepError.py:122
msgid "No error"
msgstr "Aucune erreur"

#. Translators: Message reported when calling the "report last error" command
#: addon\globalPlugins\ndtt\beepError.py:126
msgid "Last error cleared"
msgstr "Dernière erreur effacée"

#. Translators: The name of a category in the Input gesture dialog
#: addon\globalPlugins\ndtt\extScriptDesc.py:19
msgid "Scripts without description (modify at your own risk!)"
msgstr "Scripts sans description (à modifier à vos risques et périls !)"

#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\extScriptDesc.py:65
msgid "Toggles the extended script description mode."
msgstr "Active ou désactive le mode de description étendue des scripts."

#. Translators: A message reported when toggling Extended script description mode.
#: addon\globalPlugins\ndtt\extScriptDesc.py:79
msgid "Extended script description mode enabled"
msgstr "Mode de description étendue des scripts activé"

#. pyright: ignore[reportPrivateUsage]
#. Translators: A message reported when toggling Extended script description mode.
#: addon\globalPlugins\ndtt\extScriptDesc.py:83
msgid "Extended script description mode disabled"
msgstr "Mode de description étendue des scripts désactivé"

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:60
msgid ""
"No path configured for NVDA sources; please see documentation to configure "
"it."
msgstr ""
"Aucun chemin configuré pour les sources NVDA ; veuillez consulter la "
"documentation pour le configurer."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:65
msgid ""
"No open file command configured; please see documentation to configure it."
msgstr ""
"Aucune commande d'ouverture de fichier configurée ; veuillez consulter la "
"documentation pour la configurer."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:71
msgid ""
"Wrong format for the open file command in the configuration; please see "
"documentation to configure it."
msgstr ""
"Format incorrect pour la commande d'ouverture de fichier dans la "
"configuration ; veuillez consulter la documentation pour la configurer."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:78
msgid "Editor not found at {}; please check your configuration."
msgstr "Éditeur non trouvé à {} ; veuillez vérifier votre configuration."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:83
msgid "Object not found: {}"
msgstr "Objet non trouvé : {}"

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:88
msgid "File not found: {}"
msgstr "Fichier non trouvé : {}"

#. Translators: A possible choice for function calls log method setting
#: addon\globalPlugins\ndtt\functionCallsLogging.py:30
msgid "Monkey patching"
msgstr "Monkey patching"

#. Translators: A possible choice for function calls log method setting
#: addon\globalPlugins\ndtt\functionCallsLogging.py:32
msgid "settrace"
msgstr "settrace"

#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:45
msgid "Toggles the function calls log."
msgstr "Active ou désactive la journalisation des appels de fonction."

#. Translators: Reported when toggling the function call log feature.
#: addon\globalPlugins\ndtt\functionCallsLogging.py:52
#, python-brace-format
