msgstr "&Fermer"

#. We open the message box only if no log can be opened
#. Translators: A message displayed to the user when pressing the Open button in the logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:543
msgid "The selected log(s) is (are) not available anymore"
msgstr "Le(s) journal(aux) sélectionné(s) n'est (ne sont) plus disponible(s)"

#. Translators: A message displayed to the user when pressing the Delete button in the logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:549
#, python-brace-format
msgid ""
"The following files will be removed:\n"
"{logsList}\n"
"\n"
"Would you like to continue?"
msgstr ""
"Les fichiers suivants seront supprimés :\n"
"{logsList}\n"
"\n"
"Voulez-vous continuer?"

#. Translators: The title of a dialog displayed to the user when pressing the Delete button in the
#. logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:554
msgid "Confirm deletion"
msgstr "Confirmer la suppression"

#. Translators: Message issued when 5 or more logs could not be deleted.
#: addon\globalPlugins\ndtt\logManagement.py:584
#, python-brace-format
msgid "{nLogs} log files could not be deleted. See NVDA's log for details."
msgstr ""
"{nLogs} fichiers de journal n'ont pas pu être supprimés. Voir le journal de "
"NVDA pour plus de détails."

#. Translators: Message issued when 1 to 4 logs could not be deleted.
#: addon\globalPlugins\ndtt\logManagement.py:590
#, python-brace-format
msgid ""
"The following logs files could not be deleted.\n"
"\n"
"{files}"
msgstr ""
"Les fichiers journaux suivants n'ont pas pu être supprimés.\n"
"\n"
"{files}"

#. Translators: The title of a dialog displayed to the user when pressing the Delete button in
#. the logs manager dialog
#. Translators: The title of a dialog displayed to the user when copying files in the logs manager dialog
#. fails
#. Translators: Caption of the message box error when calling the anonymization command
#: addon\globalPlugins\ndtt\logManagement.py:595
#: addon\globalPlugins\ndtt\logManagement.py:631
#: addon\globalPlugins\ndtt\logManagement.py:713
msgid "Error"
msgstr "Erreur"

#. Translators: reported when requesting to copy the logs selected in the logs manager dialog.
#: addon\globalPlugins\ndtt\logManagement.py:637
msgid "Log files copied"
msgstr "Fichiers de journal copiés"

#. Translators: reported when requesting to copy the logs selected in the logs manager dialog.
#: addon\globalPlugins\ndtt\logManagement.py:641
msgid "Unable to copy the selected logs; the clipboard is not available."
msgstr ""
"Impossible de copier les journaux sélectionnés; Le presse-papiers n'est pas "
"disponible."

#. Translators: menu item label to open the logs manager dialog.
#: addon\globalPlugins\ndtt\logManagement.py:659
msgid "&Logs manager..."
msgstr "&Gestionnaire de journaux..."

#. Translators: Input help mode message for Copy and anonymize log script.
#: addon\globalPlugins\ndtt\logManagement.py:682
msgid "Copy the selection and anonymize it."
msgstr "Copie et anonymise la sélection."

#. Translators: a message reported when calling the anonymization command
#: addon\globalPlugins\ndtt\logManagement.py:699
msgid "No selection"
msgstr "Aucune sélection"

#. Translators: a message reported when calling the anonymization command
#: addon\globalPlugins\ndtt\logManagement.py:704
msgid "Selected text anonymized and copied in the clipboard."
msgstr "Le texte sélectionné a été anonymisé et copié dans le presse-papiers."

#. Translators: message of the message box error when calling the anonymization command
#: addon\globalPlugins\ndtt\logManagement.py:711
msgid ""
"Could not anonymize and copy selection.\n"
"\n"
"{}"
msgstr ""
"Impossible d'anonymiser et copier la sélection.\n"
"\n"
"{}"

#. Translators: a message reported when calling the anonymization command
#: addon\globalPlugins\ndtt\logManagement.py:738
msgid ""
"Invalid regular expression in anonymization rules file.\n"
"\n"
"File: {}\n"
"Line: {}\n"
"Pattern: {}\n"
"Error: {}"
msgstr ""
"Expression régulière non valide dans le fichier de règles d'anonymisation.\n"
"\n"
"Fichier : {}\n"
"Ligne : {}\n"
"Pattern : {}\n"
"Erreur : {}"

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon\globalPlugins\ndtt\logReader.py:828
msgid "No more item"
msgstr "Aucun autre élément"

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon\globalPlugins\ndtt\logReader.py:880
msgid "No more block"
msgstr "Aucun autre bloc"

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon\globalPlugins\ndtt\logReader.py:897
msgid "No block here"
msgstr "Aucun bloc ici"

#. Translators: Reported when pressing the Go to error command in the log
#: addon\globalPlugins\ndtt\logReader.py:919
msgid "No error indicator for this frame"
msgstr "Aucun indicateur d'erreur dans cette frame"

#. Translators: Reported when pressing the go to error command in a traceback line.
#: addon\globalPlugins\ndtt\logReader.py:948
msgid "No traceback here"
msgstr ""
"Amener le curseur à la position de l'erreur dans une frame de pile d'appel "
"(traceback). Un deuxième appui sélectionne le code erroné. Un troisième "
"appui sélectionne l'erreur avec son contexte."

#. Translators: Input help mode message for log navigation commands. {st} will be replaced by
#. the search type (Io, Debug, Message, etc.
#: addon\globalPlugins\ndtt\logReader.py:965
#, python-brace-format
msgid "Moves to the next logged message of type {st}."
msgstr "Se déplace au message journalisé suivant de type {st}."

#. Translators: Input help mode message for log navigation commands. {st} will be replaced by the
#. search type (Io, Debug, Message, etc.
#: addon\globalPlugins\ndtt\logReader.py:969
#, python-brace-format
msgid "Moves to the previous logged message of type {st}."
msgstr "Se déplace au précédent message journalisé de type {st}."

#. Translators: A message reported when toggling log reader commands.
#: addon\globalPlugins\ndtt\logReader.py:1064
msgid "Log Reader commands enabled."
msgstr "Commandes de lecture de journal activées."

#. Translators: A message reported when toggling log reader commands.
#: addon\globalPlugins\ndtt\logReader.py:1067
msgid "Log Reader commands disabled."
msgstr "Commandes de lecture de journal désactivées."

#. Translators: Input help mode message for Toggle log translation script.
#: addon\globalPlugins\ndtt\logReader.py:1072
msgid "Toggles speech translation in the log"
msgstr "Active ou désactive la traduction de la parole dans le journal"

#. Translators: A message reported when disabling log translation.
#: addon\globalPlugins\ndtt\logReader.py:1079
msgid "Log translation disabled"
msgstr "Traduction du journal désactivée"

#. Translators: A message reported when enabling log translation.
#: addon\globalPlugins\ndtt\logReader.py:1084
msgid "Log translation enabled"
msgstr "Traduction du journal activée"

#. Translators: A message reported when trying to enable log translation.
#: addon\globalPlugins\ndtt\logReader.py:1088
msgid ""
"Cannot enable log translation. Please install or enable Instant Translate "
"add-on."
msgstr ""
"Impossible d'activer la traduction du journal. Veuillez installer ou activer "
"l'extension Instant Translate."

#. Translators: Input help mode message for Open source file script.
#: addon\globalPlugins\ndtt\logReader.py:1093
msgid ""
"Opens the source code file whose path is located at the caret's position."
msgstr ""
"Ouvre le fichier de code source sur le chemin duquel est situé le curseur."

#. Translators: A message reported when trying to open the source code from the current line.
#: addon\globalPlugins\ndtt\logReader.py:1113
msgid "No file path or object found on this line."
msgstr "Aucun chemin de fichier ni objet trouvé sur cette ligne."

#. Translators: Input help mode message for go to error script.
#: addon\globalPlugins\ndtt\logReader.py:1118
msgid ""
"Move the caret at the error's position in a traceback frame. A second press "
"selects the erroneous code. A third press selects the error with its context."
msgstr ""
"Amener le curseur à la position de l'erreur dans une frame de pile d'appel "
"(traceback). Un deuxième appui sélectionne le code erroné. Un troisième "
"appui sélectionne l'erreur avec son contexte."

#. Translators: A message reported when using block navigation command
#: addon\globalPlugins\ndtt\logReader.py:1145
#: addon\globalPlugins\ndtt\logReader.py:1175
msgid "Not in a log message"
msgstr "Pas dans un message de journal"

#. Translators: A message reported when using block navigation command
#: addon\globalPlugins\ndtt\logReader.py:1150
#: addon\globalPlugins\ndtt\logReader.py:1180
msgid "No block in this message"
msgstr "Aucun bloc dans ce message"

#. Translators: Input help mode message for Log Reader help script.
#: addon\globalPlugins\ndtt\logReader.py:1202
msgid "Displays help for the Log reader commands"
msgstr "Affiche l'aide pour les commandes du lecteur de journal"

#. Translators: Title of the Log Reader commands help window.
#: addon\globalPlugins\ndtt\logReader.py:1207
#, python-brace-format
msgid "Log Reader commands ({name})"
msgstr "Commandes du Lecteur de journal ({name})"

#. Translators: Input help mode message for Add marker in log script.
#: addon\globalPlugins\ndtt\logReader.py:1317
msgid "Adds a marker in the log."
msgstr "Ajoute un marqueur dans le journal."

#. Translators: a message telling the user that a marker has been inserted in the log.
#: addon\globalPlugins\ndtt\logReader.py:1324
msgid "Marker {} added in the log"
msgstr "Marqueur {} ajouté dans le journal"

#. Translators: Input help mode message for Toggle log Reader script.
#: addon\globalPlugins\ndtt\logReader.py:1329
msgid "Activates or deactivates the log Reader commands."
msgstr "Active ou désactive les commandes de lecture de journal."

#. Translators: A message when using Toggle log Reader script.
#: addon\globalPlugins\ndtt\logReader.py:1344
msgid "Not in a text area."
msgstr "Pas dans une zone de texte."

#. Translators: This is a label of an item for the backup combo box in the NDTT Settings panel.
#: addon\globalPlugins\ndtt\ndttGui.py:40
